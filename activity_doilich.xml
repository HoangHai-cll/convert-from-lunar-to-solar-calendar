<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CHUYỂN ĐỔI LỊCH ÂM - DƯƠNG"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"/>

    <EditText
        android:id="@+id/edtDay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập ngày (VD: 15)"
        android:inputType="number" />

    <EditText
        android:id="@+id/edtMonth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập tháng (VD: 8)"
        android:inputType="number" />

    <EditText
        android:id="@+id/edtYear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nhập năm (VD: 2026)"
        android:inputType="number" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="15dp">

        <Button
            android:id="@+id/btnToLunar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Dương -> Âm"
            android:layout_marginEnd="5dp"/>

        <Button
            android:id="@+id/btnToSolar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Âm -> Dương" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtResultConvert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="#F0F0F0"
        android:padding="15dp"
        android:text="Kết quả hiển thị tại đây"
        android:textSize="18sp"
        android:textColor="#2E7D32"
        android:textStyle="italic" />

</LinearLayout>